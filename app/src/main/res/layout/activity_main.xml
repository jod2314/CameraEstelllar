<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Visor de Cámara -->
    <SurfaceView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Capa de Filtro Rojo (Red Light Mode) -->
    <View
        android:id="@+id/redFilter"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60FF0000"
        android:visibility="visible" />

    <!-- Panel de Controles Profesionales -->
    <LinearLayout
        android:id="@+id/controlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CameraStellar v3 - Listo"
            android:textColor="#FF0000"
            android:textAlignment="center"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Control de ISO -->
        <TextView
            android:id="@+id/isoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ISO: 800"
            android:textColor="#FF0000" />
        <SeekBar
            android:id="@+id/isoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="6400"
            android:progress="800"
            android:progressTint="#FF0000"
            android:thumbTint="#FF0000" />

        <!-- Control de Exposición -->
        <TextView
            android:id="@+id/exposureLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exposición: 1.0s"
            android:textColor="#FF0000"
            android:layout_marginTop="10dp" />
        <SeekBar
            android:id="@+id/exposureSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="30"
            android:progress="1"
            android:progressTint="#FF0000"
            android:thumbTint="#FF0000" />

        <!-- Control de Ráfaga -->
        <TextView
            android:id="@+id/burstLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fotos en Ráfaga: 1"
            android:textColor="#FF0000"
            android:layout_marginTop="10dp" />
        <SeekBar
            android:id="@+id/burstSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="50"
            android:progress="1"
            android:progressTint="#FF0000"
            android:thumbTint="#FF0000" />

        <Button
            android:id="@+id/captureButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:text="INICIAR CAPTURA ESTELAR"
            android:textColor="#000000"
            android:textStyle="bold"
            android:backgroundTint="#FF0000" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
