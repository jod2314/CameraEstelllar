<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Visor de Cámara -->
    <SurfaceView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Informe de Auditoría de Sensores (Capa Superior Traslúcida) -->
    <LinearLayout
        android:id="@+id/auditPanel"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#80000000"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AUDITORÍA DE HARDWARE ESTELAR"
            android:textColor="#00FF00"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="5dp">
            <TextView
                android:id="@+id/auditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Escaneando..."
                android:textColor="#00FF00"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </ScrollView>

        <Button
            android:id="@+id/closeAuditButton"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="end"
            android:padding="0dp"
            android:text="Cerrar Info"
            android:textSize="10sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Capa de Filtro Rojo (Red Light Mode) -->
    <View
        android:id="@+id/redFilter"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60FF0000"
        android:visibility="visible" />

    <!-- Botón de Cambio de Lente -->
    <Button
        android:id="@+id/switchLensButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Cambiar Lente"
        android:textColor="#000000"
        android:backgroundTint="#FF0000"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Panel de Controles Profesionales -->
    <LinearLayout
        android:id="@+id/controlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/metadataText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Real-time: --"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            android:textSize="10sp"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CameraStellar v3 - Listo"
            android:textColor="#FF0000"
            android:textAlignment="center"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Control de ISO -->
        <TextView
            android:id="@+id/isoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ISO: 800"
            android:textColor="#FF0000" />
        <SeekBar
            android:id="@+id/isoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="6400"
            android:progress="800"
            android:progressTint="#FF0000"
            android:thumbTint="#FF0000" />

        <!-- Control de Exposición -->
        <TextView
            android:id="@+id/exposureLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exposición: 1.0s"
            android:textColor="#FF0000"
            android:layout_marginTop="10dp" />
        <SeekBar
            android:id="@+id/exposureSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="30"
            android:progress="1"
            android:progressTint="#FF0000"
            android:thumbTint="#FF0000" />

        <!-- Control de Ráfaga -->
        <TextView
            android:id="@+id/burstLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fotos en Ráfaga: 1"
            android:textColor="#FF0000"
            android:layout_marginTop="10dp" />
        <SeekBar
            android:id="@+id/burstSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="20"
            android:progress="1"
            android:progressTint="#FF0000"
            android:thumbTint="#FF0000" />

        <Button
            android:id="@+id/captureButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:text="INICIAR CAPTURA ESTELAR"
            android:textColor="#000000"
            android:textStyle="bold"
            android:backgroundTint="#FF0000" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
